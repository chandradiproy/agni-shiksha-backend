// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. USERS & AUTHENTICATION
// ==========================================

model User {
  id            String  @id @default(uuid()) @db.Uuid
  phone_number  String  @unique @db.VarChar(15)
  email         String? @unique @db.VarChar(255)
  password_hash String? @db.VarChar(255) // Optional for MVP if using only OTP/Google
  full_name     String? @db.VarChar(100)
  avatar_id     Int     @default(1)

  target_exam_id    String?   @db.Uuid
  exam_date         DateTime? @db.Date
  study_language    String    @default("hindi") @db.VarChar(20)
  prep_level        String    @default("beginner") @db.VarChar(20)
  daily_study_hours Int       @default(2) @db.SmallInt

  is_premium         Boolean   @default(false)
  premium_plan_id    String?   @db.Uuid
  premium_expires_at DateTime? @db.Timestamptz

  xp_total           Int       @default(0)
  xp_current_level   Int       @default(0)
  level              Int       @default(1)
  gems               Int       @default(50)
  current_streak     Int       @default(0)
  longest_streak     Int       @default(0)
  last_activity_date DateTime? @db.Date
  streak_freezes     Int       @default(2) @db.SmallInt

  is_email_verified Boolean @default(false)
  is_phone_verified Boolean @default(false)
  is_active         Boolean @default(true)
  is_banned         Boolean @default(false)
  ban_reason        String? @db.Text
  forum_banned  Boolean  @default(false) // <-- NEW: Block forum access only

  device_tokens       Json    @default("[]")
  device_fingerprints Json    @default("[]")
  referral_code       String? @unique @db.VarChar(12)
  referred_by_id      String? @db.Uuid

  onboarding_completed Boolean @default(false)
  biometric_enabled    Boolean @default(false)

  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz

  // Relations
  target_exam   Exam?          @relation("UserTargetExam", fields: [target_exam_id], references: [id])
  premium_plan  Plan?          @relation("UserPremiumPlan", fields: [premium_plan_id], references: [id])
  referred_by   User?          @relation("UserReferrals", fields: [referred_by_id], references: [id])
  referrals     User[]         @relation("UserReferrals")
  sessions      UserSession[]
  test_attempts TestAttempt[]
  payments      Payment[]
  subscriptions Subscription[]
  doubts          Doubt[]        // <-- NEW RELATION
  doubt_answers   DoubtAnswer[]  // <-- NEW RELATION
  reports_made    Report[]       // <-- NEW RELATION
  transactions  PaymentTransaction[] // New relation

  @@index([phone_number])
  @@index([xp_total(sort: Desc)])
  @@index([target_exam_id])
  @@map("users")
}

model UserSession {
  id                 String   @id @default(uuid()) @db.Uuid
  user_id            String   @db.Uuid
  jwt_token_hash     String   @unique @db.VarChar(255)
  device_fingerprint String   @db.VarChar(255)
  device_name        String?  @db.VarChar(100)
  ip_address         String?  @db.Inet
  user_agent         String?  @db.Text
  is_active          Boolean  @default(true)
  expires_at         DateTime @db.Timestamptz
  created_at         DateTime @default(now()) @db.Timestamptz

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model OtpVerification {
  id             String   @id @default(uuid()) @db.Uuid
  phone_or_email String   @db.VarChar(255)
  otp_hash       String   @db.VarChar(255)
  purpose        String   @db.VarChar(30)
  attempts       Int      @default(0) @db.SmallInt
  is_used        Boolean  @default(false)
  expires_at     DateTime @db.Timestamptz
  created_at     DateTime @default(now()) @db.Timestamptz

  @@map("otp_verifications")
}

// ==========================================
// 2. EXAMS & TESTS
// ==========================================

model Exam {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(100)
  slug            String   @unique @db.VarChar(50)
  category        String   @db.VarChar(50)
  conducting_body String   @db.VarChar(100)
  description     String?  @db.Text
  thumbnail_url   String?  @db.VarChar(500)
  is_active       Boolean  @default(true)
  display_order   Int      @db.SmallInt
  subjects        Json     @default("[]")
  exam_pattern    Json     @default("{}")
  created_by      String?  @db.Uuid
  updated_by      String?  @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamptz

  users          User[]          @relation("UserTargetExam")
  test_series    TestSeries[]
  questions      Question[]
  study_plans     StudyPlan[]
  study_materials StudyMaterial[]
  creator         AdminUser?      @relation("ExamCreator", fields: [created_by], references: [id])
  updater         AdminUser?      @relation("ExamUpdater", fields: [updated_by], references: [id])

  @@map("exams")
}

model TestSeries {
  id                       String    @id @default(uuid()) @db.Uuid
  exam_id                  String    @db.Uuid
  title                    String    @db.VarChar(200)
  description              String?   @db.Text
  type                     String    @db.VarChar(30) // free/premium/premium_plus
  test_type                String    @db.VarChar(30) // full_mock/sectional/mini/pyq/ca
  subject                  String?   @db.VarChar(100)
  total_questions          Int       @db.SmallInt
  duration_minutes         Int       @db.SmallInt
  total_marks              Int       @db.SmallInt
  negative_marking         Boolean   @default(false)
  negative_marks_per_wrong Decimal   @default(0.00) @db.Decimal(3, 2)
  difficulty               String    @db.VarChar(20)
  is_all_india             Boolean   @default(false)
  is_active                Boolean   @default(true)
  is_scheduled             Boolean   @default(false)
  is_published             Boolean   @default(false)
  scheduled_at             DateTime? @db.Timestamptz
  available_from           DateTime  @default(now()) @db.Timestamptz
  available_until          DateTime? @db.Timestamptz
  max_attempts             Int       @default(3) @db.SmallInt
  show_solutions           Boolean   @default(true)
  show_solutions_after     String    @default("immediate") @db.VarChar(20)
  instructions             String?   @db.Text
  sections                 Json      @default("[]")
  price_if_standalone      Int?
  created_by               String?   @db.Uuid
  updated_by               String?   @db.Uuid
  created_at               DateTime  @default(now()) @db.Timestamptz
  updated_at               DateTime  @default(now()) @updatedAt @db.Timestamptz

  exam      Exam          @relation(fields: [exam_id], references: [id])
  questions Question[]
  attempts  TestAttempt[]
  creator   AdminUser?    @relation("TestCreator", fields: [created_by], references: [id])
  updater   AdminUser?    @relation("TestUpdater", fields: [updated_by], references: [id])

  @@index([exam_id, is_active])
  @@index([type, is_active])
  @@map("test_series")
}

model Question {
  id                      String   @id @default(uuid()) @db.Uuid
  test_series_id          String?  @db.Uuid
  exam_id                 String   @db.Uuid
  subject                 String   @db.VarChar(100)
  topic                   String   @db.VarChar(150)
  sub_topic               String?  @db.VarChar(150)
  section                 String   @db.VarChar(100)
  question_type           String   @db.VarChar(30) // mcq/true_false/fill_blank
  question_text           String   @db.Text
  question_text_hindi     String?  @db.Text
  options                 Json // Array of {id, text, is_correct}
  correct_option_id       String   @db.VarChar(10)
  explanation             String   @db.Text
  explanation_hindi       String?  @db.Text
  explanation_video_url   String?  @db.VarChar(500)
  difficulty              String   @db.VarChar(20)
  question_type_cognitive String   @db.VarChar(30) // conceptual/calculation/memory
  marks                   Int      @default(1) @db.SmallInt
  tags                    String[] // Array of strings
  source                  String   @db.VarChar(50)
  pyq_year                Int?     @db.SmallInt
  is_active               Boolean  @default(true)
  display_order           Int      @db.SmallInt
  created_by              String?  @db.Uuid
  created_at              DateTime @default(now()) @db.Timestamptz

  test_series TestSeries? @relation(fields: [test_series_id], references: [id])
  exam        Exam        @relation(fields: [exam_id], references: [id])
  admin       AdminUser?  @relation(fields: [created_by], references: [id])

  @@index([test_series_id, display_order])
  @@map("questions")
}

model TestAttempt {
  id                 String    @id @default(uuid()) @db.Uuid
  user_id            String    @db.Uuid
  test_series_id     String    @db.Uuid
  attempt_number     Int       @db.SmallInt
  status             String    @default("in_progress") @db.VarChar(20)
  started_at         DateTime  @default(now()) @db.Timestamptz
  submitted_at       DateTime? @db.Timestamptz
  time_taken_seconds Int?
  score              Decimal?  @db.Decimal(6, 2)
  max_score          Decimal?  @db.Decimal(6, 2)
  percentage         Decimal?  @db.Decimal(5, 2)
  correct_count      Int?      @db.SmallInt
  incorrect_count    Int?      @db.SmallInt
  unattempted_count  Int?      @db.SmallInt
  all_india_rank     Int?
  percentile         Decimal?  @db.Decimal(5, 2)
  subject_scores     Json?
  section_scores     Json?
  topic_scores       Json?
  answers            Json      @default("[]")
  device_fingerprint String?   @db.VarChar(255)
  ip_address         String?   @db.Inet
  tab_switches       Int       @default(0) @db.SmallInt
  xp_earned          Int       @default(0) @db.SmallInt
  created_at         DateTime  @default(now()) @db.Timestamptz

  user        User       @relation(fields: [user_id], references: [id])
  test_series TestSeries @relation(fields: [test_series_id], references: [id])

  @@unique([user_id, test_series_id, attempt_number])
  @@index([user_id, test_series_id])
  @@index([status])
  @@index([submitted_at(sort: Desc)])
  @@map("test_attempts")
}

// ==========================================
// 3. PAYMENTS & SUBSCRIPTIONS
// ==========================================

model Plan {
  id                  String  @id @default(uuid()) @db.Uuid
  name                String  @db.VarChar(100)
  slug                String  @unique @db.VarChar(50)
  monthly_price_paise Int
  annual_price_paise  Int
  features            Json
  is_active           Boolean @default(true)
  display_order       Int     @db.SmallInt

  users         User[]         @relation("UserPremiumPlan")
  subscriptions Subscription[]
  payments      Payment[]
  coupons       Coupon[]       // NEW: Relation to Coupons

  @@map("plans")
}

model Subscription {
  id              String   @id @default(uuid()) @db.Uuid
  user_id         String   @db.Uuid
  plan_id         String   @db.Uuid
  started_at      DateTime @db.Timestamptz
  expires_at      DateTime @db.Timestamptz
  status          String   @db.VarChar(30)
  auto_renew      Boolean  @default(false)
  payment_gateway String   @db.VarChar(50)

  user User @relation(fields: [user_id], references: [id])
  plan Plan @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

// NEW COUPON MODEL
model Coupon {
  id                 String    @id @default(uuid()) @db.Uuid
  code               String    @unique @db.VarChar(50)
  discount_type      String    @db.VarChar(20) // 'PERCENTAGE' or 'FLAT'
  discount_value     Float     // e.g., 20 for 20%, or 500 for 500 INR flat off
  max_uses           Int?      // Null means unlimited uses
  current_uses       Int       @default(0)
  valid_from         DateTime  @default(now()) @db.Timestamptz
  valid_until        DateTime? @db.Timestamptz // Null means no expiry
  is_active          Boolean   @default(true)
  applicable_plan_id String?   @db.Uuid // Null means applies to ALL plans

  created_at DateTime @default(now()) @db.Timestamptz

  applicable_plan Plan?     @relation(fields: [applicable_plan_id], references: [id])
  payments        Payment[]

  @@map("coupons")
}

model Payment {
  id                 String   @id @default(uuid()) @db.Uuid
  user_id            String   @db.Uuid
  amount_paise       Int
  currency           String   @default("INR") @db.VarChar(10)
  gateway            String   @default("razorpay") @db.VarChar(50)
  gateway_order_id   String   @unique @db.VarChar(255)
  gateway_payment_id String?  @unique @db.VarChar(255)
  status             String   @default("created") @db.VarChar(30)
  plan_id            String?  @db.Uuid
  coupon_id          String?  @db.Uuid // NEW: Track the coupon used
  description        String?  @db.Text
  created_at         DateTime @default(now()) @db.Timestamptz

  user User  @relation(fields: [user_id], references: [id])
  plan Plan? @relation(fields: [plan_id], references: [id])
  coupon Coupon? @relation(fields: [coupon_id], references: [id]) // NEW Relation

  @@index([user_id, created_at(sort: Desc)])
  @@index([status, created_at(sort: Desc)])
  @@index([gateway_order_id])
  @@map("payments")
}

// ==========================================
// 4. ADMIN USERS
// ==========================================

model AdminUser {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  name          String    @db.VarChar(100)
  role          String    @db.VarChar(50) // super_admin/content/analytics/support/finance
  password_hash String    @db.VarChar(255)
  is_active     Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime   @default(now()) @db.Timestamptz
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz

  created_questions Question[]

    // Relations mapping to content creation/updates
  //questions         Question[]
  
  created_exams     Exam[]          @relation("ExamCreator")
  updated_exams     Exam[]          @relation("ExamUpdater")
  
  created_tests     TestSeries[]    @relation("TestCreator")
  updated_tests     TestSeries[]    @relation("TestUpdater")
  
  created_materials StudyMaterial[] @relation("MaterialCreator")
  updated_materials StudyMaterial[] @relation("MaterialUpdater")
  
  created_plans     StudyPlan[]     @relation("PlanCreator")
  updated_plans     StudyPlan[]     @relation("PlanUpdater")
  
  created_articles  Article[]       @relation("ArticleCreator")
  updated_articles  Article[]       @relation("ArticleUpdater")
  
  audit_logs        AdminAuditLog[]

  @@map("admin_users")
}

model AdminAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  admin_id    String   @db.Uuid
  action      String   @db.VarChar(100) // e.g., "BANNED_USER", "DELETED_TEST"
  target_id   String   @db.Uuid         // The ID of the item affected
  details     Json?                     // Additional metadata
  created_at  DateTime @default(now()) @db.Timestamptz

  admin       AdminUser @relation(fields: [admin_id], references: [id])

  @@index([admin_id])
  @@index([action])
  @@map("admin_audit_logs")
}

model Article {
  id           String   @id @default(uuid()) @db.Uuid
  title        String   @db.VarChar(500)
  summary      String   @db.Text
  content      String?  @db.Text // <-- NEW: Full HTML/Markdown body
  source_name  String   @db.VarChar(100)
  source_url   String?  @unique @db.VarChar(1000) // <-- CHANGED: Nullable for custom articles
  image_url    String?  @db.Text
  is_custom    Boolean  @default(false) // <-- NEW: Flag to identify admin-created news
  published_at DateTime @db.Timestamptz
  is_hidden    Boolean  @default(false)
  is_pinned    Boolean  @default(false)
  created_by   String?  @db.Uuid
  updated_by   String?  @db.Uuid
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @default(now()) @updatedAt @db.Timestamptz

  creator      AdminUser? @relation("ArticleCreator", fields: [created_by], references: [id])
  updater      AdminUser? @relation("ArticleUpdater", fields: [updated_by], references: [id])


  @@index([published_at(sort: Desc)])
  @@index([is_hidden])
  @@map("articles")
}

model StudyMaterial {
  id            String   @id @default(uuid()) @db.Uuid
  exam_id       String   @db.Uuid
  title         String   @db.VarChar(200)
  subject       String   @db.VarChar(100)
  topic         String   @db.VarChar(200)
  material_type String   @db.VarChar(20) // e.g., 'PDF', 'VIDEO_  LINK'
  file_url      String   @db.Text
  is_active     Boolean  @default(true)
  is_premium    Boolean  @default(false) // <-- Crucial flag for Soft Gate
  created_by    String?  @db.Uuid
  updated_by    String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  exam          Exam     @relation(fields: [exam_id], references: [id])
  tasks         StudyPlanTask[]
  creator       AdminUser?      @relation("MaterialCreator", fields: [created_by], references: [id])
  updater       AdminUser?      @relation("MaterialUpdater", fields: [updated_by], references: [id])


  @@map("study_materials")
}

model StudyPlan {
  id            String   @id @default(uuid()) @db.Uuid
  exam_id       String   @db.Uuid
  title         String   @db.VarChar(200)
  duration_days Int      @db.SmallInt
  created_by    String?  @db.Uuid
  updated_by    String?  @db.Uuid
  created_at    DateTime @default(now()) @db.Timestamptz
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz

  exam          Exam     @relation(fields: [exam_id], references: [id])
  tasks         StudyPlanTask[]
  creator       AdminUser?      @relation("PlanCreator", fields: [created_by], references: [id])
  updater       AdminUser?      @relation("PlanUpdater", fields: [updated_by], references: [id])

  @@map("study_plans")
}

model StudyPlanTask {
  id                    String   @id @default(uuid()) @db.Uuid
  study_plan_id         String   @db.Uuid
  day_number            Int      @db.SmallInt
  task_title            String   @db.VarChar(200)
  task_description      String?  @db.Text
  reference_material_id String?  @db.Uuid
  created_at            DateTime @default(now()) @db.Timestamptz
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz

  plan                  StudyPlan       @relation(fields: [study_plan_id], references: [id], onDelete: Cascade)
  material              StudyMaterial?  @relation(fields: [reference_material_id], references: [id], onDelete: SetNull)

  @@index([study_plan_id, day_number])
  @@map("study_plan_tasks")
}
model Doubt {
  id          String   @id @default(uuid()) @db.Uuid
  user_id     String   @db.Uuid
  title       String   @db.VarChar(300)
  description String   @db.Text
  subject     String?  @db.VarChar(100)
  image_url   String?  @db.Text
  upvotes     Int      @default(0)
  is_resolved Boolean  @default(false)
  is_flagged  Boolean  @default(false) // True if reported by community
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  user        User          @relation(fields: [user_id], references: [id])
  answers     DoubtAnswer[]

  @@map("doubts")
}

model DoubtAnswer {
  id          String   @id @default(uuid()) @db.Uuid
  doubt_id    String   @db.Uuid
  user_id     String   @db.Uuid
  content     String   @db.Text
  image_url   String?  @db.VarChar(255) // ADDED: Allows students to upload solution images
  upvotes     Int      @default(0)
  is_accepted Boolean  @default(false)
  is_flagged  Boolean  @default(false) // True if reported by community
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz

  doubt       Doubt    @relation(fields: [doubt_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id])

  @@map("doubt_answers")
}

model Report {
  id                  String   @id @default(uuid()) @db.Uuid
  reported_by_user_id String   @db.Uuid
  item_id             String   @db.Uuid // UUID of Doubt or DoubtAnswer
  item_type           String   @db.VarChar(50) // 'DOUBT' or 'ANSWER'
  reason              String   @db.Text
  status              String   @default("PENDING") @db.VarChar(50) // 'PENDING' or 'RESOLVED'
  created_at          DateTime @default(now()) @db.Timestamptz

  reporter            User     @relation(fields: [reported_by_user_id], references: [id])

  @@map("reports")
}

// ==========================================
// 8. GAMIFICATION CONFIGURATION
// ==========================================

model QuestConfig {
  id             String   @id @default(uuid()) @db.Uuid
  title          String   @db.VarChar(200)
  description    String   @db.Text
  xp_reward      Int      @db.SmallInt
  target_action  String   @db.VarChar(50) // e.g., 'TAKE_TEST', 'READ_ARTICLE', 'ASK_DOUBT'
  target_count   Int      @db.SmallInt
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamptz
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("quest_configs")
}

model BadgeConfig {
  id                   String   @id @default(uuid()) @db.Uuid
  badge_name           String   @db.VarChar(100)
  description          String   @db.Text
  icon_url             String   @db.Text
  unlock_xp_threshold  Int
  created_at           DateTime @default(now()) @db.Timestamptz
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz

  @@map("badge_configs")
}

model PaymentTransaction {
  id               String   @id @default(uuid()) @db.Uuid
  user_id          String   @db.Uuid
  razorpay_order_id String   @unique @db.VarChar(255)
  razorpay_payment_id String?  @unique @db.VarChar(255)
  amount           Decimal    @db.Decimal(10, 2)
  currency         String   @default("INR") @db.VarChar(10)
  status           String   @default("CREATED") @db.VarChar(50) // 'CREATED', 'SUCCESS', 'FAILED'
  plan_id          String   @db.Uuid // UUID of the selected premium plan
  error_message    String?  @db.Text
  created_at       DateTime @default(now()) @db.Timestamptz
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz

  user User @relation(fields: [user_id], references: [id])

  @@map("payment_transactions")
}